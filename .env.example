# ── Vercel ──────────────────────────────────────────────
# Personal Access Token (https://vercel.com/account/tokens)
VERCEL_TOKEN=

# Project ID — found in Project Settings → General
VERCEL_PROJECT_ID=

# Team ID — required only for team-owned projects (optional)
VERCEL_TEAM_ID=

# ── Sentry ──────────────────────────────────────────────
# Auth Token with project:read scope
# (https://sentry.io/settings/account/api/auth-tokens/)
SENTRY_TOKEN=

# Organisation slug (e.g. "acme-inc")
SENTRY_ORG=

# Project slug (e.g. "my-svelte-app")
SENTRY_PROJECT=

# ── Supabase (optional) ──────────────────────────────────
# Set to "true" to enable Supabase monitoring
SUPABASE_ENABLED=false

# Project API URL (e.g. https://xyzxyzxyz.supabase.co)
SUPABASE_URL=

# Service Role secret key (Settings → API → service_role)
# Keep this key private — never expose it client-side
SUPABASE_SERVICE_KEY=

# Comma-separated list of table names to report row counts for
# (e.g. "users,profiles,posts")
SUPABASE_TABLES=

# ── TRMNL ───────────────────────────────────────────────
# Webhook URL for your Custom TRMNL plugin
# (Plugin → Edit → Webhook URL)
TRMNL_WEBHOOK_URL=
